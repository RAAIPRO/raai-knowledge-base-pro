# AI-База знаний PRO v3.5.0 — переменные окружения
#
# Без этого файла работают режимы 1-7 (поиск, FAQ, онбординг, регламенты, аудит — только на промпте).
# Заполните только если хотите подключить реальные источники знаний.
#
# Как использовать:
#   cp .env.example .env
#   # откройте .env и заполните нужные ключи
#
# Удалите или закомментируйте неиспользуемые строки.

# ═══════════════════════════════════════════════════
# ОБЯЗАТЕЛЬНЫЕ (для подключения к LLM вне Claude/OpenClaw)
# ═══════════════════════════════════════════════════
# Не нужны если используете Claude Code или OpenClaw с подпиской.
# Нужны только если запускаете standalone через API.

ANTHROPIC_API_KEY=""          # https://console.anthropic.com/settings/keys
OPENAI_API_KEY=""             # https://platform.openai.com/api-keys

# ═══════════════════════════════════════════════════
# Notion API — база знаний в Notion
# ═══════════════════════════════════════════════════
# Где брать: https://www.notion.so/my-integrations → New integration → Secret
# Гайд: docs/onboarding.md раздел "Notion интеграция"

NOTION_API_KEY=""             # secret_xxx...
NOTION_DATABASE_ID=""         # ID базы данных (из URL: notion.so/.../DATABASE_ID?v=...)
NOTION_WORKSPACE=""           # название воркспейса (для отображения)

# ═══════════════════════════════════════════════════
# Confluence API — корпоративная wiki Confluence
# ═══════════════════════════════════════════════════
# Где брать: https://id.atlassian.com/manage-profile/security/api-tokens

CONFLUENCE_BASE_URL=""        # https://yourcompany.atlassian.net
CONFLUENCE_USERNAME=""        # ваш email в Atlassian
CONFLUENCE_API_TOKEN=""       # токен из API Tokens
CONFLUENCE_SPACE_KEY=""       # ключ пространства (напр: ~MYSPACE)

# ═══════════════════════════════════════════════════
# Google Drive / Docs — документы в Google Drive
# ═══════════════════════════════════════════════════
# Где брать: https://console.cloud.google.com/ → Service Account → JSON key

GOOGLE_SERVICE_ACCOUNT_JSON=""       # путь к JSON-ключу сервис-аккаунта
GOOGLE_DRIVE_FOLDER_ID=""            # ID папки (из URL drive.google.com/drive/folders/FOLDER_ID)

# ═══════════════════════════════════════════════════
# Telegram — бот для поиска по базе знаний
# ═══════════════════════════════════════════════════
# Где брать бот-токен: @BotFather в Telegram → /newbot
# Где брать chat_id: @userinfobot → переслать боту любое сообщение

TELEGRAM_BOT_TOKEN=""                # токен вашего KB-бота
TELEGRAM_CHAT_ID=""                  # ваш chat_id или ID группы
TELEGRAM_KB_CHANNEL_ID=""            # ID канала (если публикуете обновления KB)

# ═══════════════════════════════════════════════════
# Векторная база (для семантического поиска)
# ═══════════════════════════════════════════════════
# По умолчанию: встроенный поиск без векторов (keywords + структура).
# Векторный поиск — опционально для >500 записей.

PINECONE_API_KEY=""           # https://app.pinecone.io/ → API Keys
PINECONE_INDEX_NAME=""        # название индекса (напр: knowledge-base)
PINECONE_ENVIRONMENT=""       # регион (напр: us-east-1-aws)

# ИЛИ Supabase pgvector (альтернатива Pinecone)
SUPABASE_URL=""               # https://xxx.supabase.co
SUPABASE_ANON_KEY=""          # anon public key

# ═══════════════════════════════════════════════════
# Web Search (для проверки актуальности внешних данных)
# ═══════════════════════════════════════════════════

TAVILY_API_KEY=""             # https://tavily.com/ (опционально)
EXA_API_KEY=""                # https://exa.ai/ (альтернатива)
